<script>
  function parsePrice(text) {
    if (!text) return 0;
    return parseFloat(
      text.replace(/[^0-9.,]/g, '').replace(',', '').replace(/(\.\d{2})\d+$/, '$1')
    );
  }

  function formatMoney(amount) {
    return `$${amount.toLocaleString('en-NZ', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    })} NZD`;
  }

  function updatePaymentAmounts() {
    const totalSpan = document.querySelector('.total-money');
    if (!totalSpan) return;

    const price = parsePrice(totalSpan.textContent);
    if (isNaN(price)) return;

    const spans = document.querySelectorAll('.mtf-monthly');
    spans.forEach((el, i) => {
      let parts = [6, 12, 4, 60];
      if (i < parts.length) {
        const months = parts[i];
        el.textContent = formatMoney(price / months);
      } else if (el.closest('.mtf-payments-banner')) {
        // Fallback for 60-month inside MTF even if other spans exist
        el.textContent = formatMoney(price / 60);
      }
    });
  }

  // Observe price changes
  const target = document.querySelector('.total-money');
  if (target) {
    const observer = new MutationObserver(updatePaymentAmounts);
    observer.observe(target, { childList: true, subtree: true });
  }

  // Fallback update triggers
  document.addEventListener('change', updatePaymentAmounts);
  document.addEventListener('click', updatePaymentAmounts);

  // Initial call
  updatePaymentAmounts();
</script>

