<script>
  
  document.addEventListener("DOMContentLoaded", function () {
  const body = document.body;
  const headings = body.querySelectorAll("h1, h2, h3, h4, h5, h6");

  let foundH1 = false;
  headings.forEach((el) => {
    if (el.tagName === "H1") {
      foundH1 = true;
      return; // keep the first <h1>
    }
    if (!foundH1) {
      // Replace with <div> preserving the content and classes
      const div = document.createElement("div");
      div.innerHTML = el.innerHTML;
      [...el.attributes].forEach(attr => div.setAttribute(attr.name, attr.value));
      el.replaceWith(div);
    }
  });
});

  

</script>
