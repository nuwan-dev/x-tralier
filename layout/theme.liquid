<script>
function addPreorderBadges() {
  if (!window.productMetafields) return;

  const rows = [];

  document.querySelectorAll('.inner.product-item[data-product-id]').forEach(card => {
    const rawId = card.getAttribute('data-product-id');
    if (!rawId) return;

    const productId = rawId.replace(/^product-/, '');

    const data = window.productMetafields.find(p => String(p.id) === productId);

    if (data) {
      rows.push({
        id: data.id,
        name: data.title,
        preorder_enabled: data.preorder
      });

      // Inject badge if not already injected
      if (data.preorder && !card.querySelector('.preorder-badge-injected')) {
        const badge = document.createElement('div');
        badge.textContent = 'PRE-ORDER';
        badge.className = 'preorder-badge-injected';
        badge.style.cssText =
          'position:absolute;top:0;right:0;z-index:3;pointer-events:none;' +
          'padding:8px 12px !important;font-size:14px;font-weight:bold;' +
          'color:#fff;line-height:1;border-radius:0;text-transform:uppercase;' +
          'background:#22c55e;';
        (card.querySelector('.product-image') || card).appendChild(badge);
      }
    }
  });
}

// Run on initial page load
document.addEventListener('DOMContentLoaded', addPreorderBadges);

// Re-run after AJAX pagination (MutationObserver for dynamic load)
const observer = new MutationObserver(() => {
  setTimeout(addPreorderBadges, 500);
});
observer.observe(document.body, { childList: true, subtree: true });
</script>

