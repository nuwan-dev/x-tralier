{%- comment -%}
  Caution! Please read https://help.shopify.com/en/manual/promoting-marketing/seo/editing-robots-txt
  before proceeding to make changes to this file.

  Last updated: 27/06/2026
{%- endcomment -%}

{% comment %} 
  1. Output all of Shopify's default robots rules unchanged.
  This automatically handles the correct Allow/Disallow rules for 
  Googlebot, Googlebot-image, and AdsBot safely.
{% endcomment %}
{% for group in robots.default_groups %}
  {{- group.user_agent -}}

  {% for rule in group.rules %}
    {{- rule -}}
  {% endfor %}

  {%- if group.sitemap != blank -%}
    {{ group.sitemap }}
  {%- endif -%}
{% endfor %}

{% comment %} 
  2. Global Spam Blocks
  Appended at the bottom to ensure ALL search engine crawlers (*)
  are blocked from accessing the injected hacker paths.
{% endcomment %}

