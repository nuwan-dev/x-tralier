</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const carousel = document.querySelector('.parts-collection-carousel');
  const list = document.querySelector('.parts-collection-list');
  if (!carousel || !list) return;

  // Clone all items for seamless scroll
  const items = Array.from(list.children);
  items.forEach(item => {
    const clone = item.cloneNode(true);
    list.appendChild(clone);
  });

  let scrollAmount = 0;
  const scrollStep = 1; // pixels per interval
  const scrollDelay = 20; // ms

  function autoScroll() {
    scrollAmount += scrollStep;
    if(scrollAmount >= list.scrollWidth / 2) scrollAmount = 0; // reset at halfway
    carousel.scrollLeft = scrollAmount;
    requestAnimationFrame(autoScroll);
  }

  requestAnimationFrame(autoScroll);
});
</script>