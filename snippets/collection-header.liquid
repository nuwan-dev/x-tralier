<style>
  {% if block.settings.display_collection_image %} 
  @media (min-width: 768px) {
    .collection-header-sections .page-header h1 {
      color: {{ block.settings.color_wrapper }};
    }
    .collection-header-sections .collection-static.page-header h1 {
      color: #000;
    }
  }
  {% endif %}
  
  @media (min-width: 1200px) {
    .collection-header-sections .collection-image img {
      height: {{ block.settings.height_img }};
    }

    {% if block.settings.display_collection_image %} 
    .collection-header.collection-header-sections {
      position: relative;
    }

    {% if block.settings.collection_header_style == 'style_1' %}
      .collection-header.collection-header-sections .collection-wrapper:not(.collection-static) {
        position: absolute;
        top: 50%;
        left: 50%;
        -moz-transform: translate(-50%, -50%);
        -o-transform: translate(-50%, -50%);
        -ms-transform: translate(-50%, -50%);
        -webkit-transform: translate(-50%, -50%);
        transform: translate(-50%, -50%);
        text-align: center;
        width: 100%;
        max-width: 500px;
        margin: 0;
      }
      {% if settings.layout_style == 'layout_style_fullwidth' %}
        .collection-header.collection-header-sections .collection-wrapper:not(.collection-static) {
            bottom: 55px;
            top: auto;
            transform: translate(-50%, 0);
        }
      {% endif %}
    {% else %}
      .layout-header--style2 .container .absolute {
        background-color: {{ block.settings.bg_color_content }};
      }
      .layout-header--style2 .container .absolute:before {
        border-color: {{ block.settings.border_color_content }};
      }
      .layout-header--style2 .container .absolute .collection-des a {
        color: {{ block.settings.color_wrapper }};
      }
    {% endif %}
    
    .collection-header.collection-header-sections .collection-static {
      position: static;
      width: 100%;
      max-width: 500px;
      margin: 30px auto 0;
      text-align: center;
    }
    
    .collection-header.collection-header-sections .collection-image {
      margin-bottom: 1px;
    }
    
    {% else %}
    .collection-template .reverse-mb {
      display: -webkit-box;
      display: -webkit-flex;
      display: -moz-flex;
      display: -ms-flexbox;
      display: flex;
      -webkit-flex-direction: column-reverse;
      -moz-flex-direction: column-reverse;
      -ms-flex-direction: column-reverse;
      flex-direction: column-reverse;
    }    
    {% endif %}
  }

.heavy-duty-collection-list{
  display:grid;
  grid-template-columns:repeat(8, minmax(0, 1fr));
  column-gap:30px;
  row-gap:26px;
  align-items:start;
  margin:20px 0 35px;
}

.heavy-duty-collection-item{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:flex-start;
  min-width:0;
  text-align:center;
  text-decoration:none !important;
}

.heavy-duty-collection-thumb{
  width:100%;
  max-width:200px;
  aspect-ratio:1 / 1;
  border:1px solid #d9d9d9;
  border-radius:12px;
  overflow:hidden;
  background:#fff;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:0px;
  margin:0 auto;
  transition:all .3s ease;
}

.heavy-duty-collection-thumb img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}

.heavy-duty-collection-item span{
  display:block;
  width:100%;
  margin-top:10px;
  font-size:14px;
  line-height:1.35;
  font-weight:600;
  color:#222 !important;
  text-align:center;
  white-space:normal;
  word-break:break-word;
  overflow-wrap:break-word;

}

.heavy-duty-collection-item:hover .heavy-duty-collection-thumb{
  border-color:#f5a623;
  transform:translateY(-2px);
}

.heavy-duty-collection-item:hover span{
  color:#f5a623 !important;
}

/* tablet = 2 lines */
@media (max-width: 1024px){
  .heavy-duty-collection-list{
    grid-template-columns:repeat(4, minmax(0, 1fr));
    column-gap:18px;
    row-gap:24px;
  }

  .heavy-duty-collection-thumb{
    max-width:88px;
  }

  .heavy-duty-collection-item span{
    font-size:14px;
  }
}

/* Horizontal carousel container */
.parts-collection-carousel {
  overflow: hidden; /* hide scrollbar completely */
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
  padding: 10px 0;
  position: relative;
}

/* Hide scrollbar for Webkit browsers */
.parts-collection-carousel::-webkit-scrollbar {
  display: none;
}

.parts-collection-list {
  display: flex;
  gap: 25px;
}

.parts-collection-list .heavy-duty-collection-item {
  flex: 0 0 80px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

/* Image size 80x80 */
.parts-collection-list .heavy-duty-collection-thumb {
  width: 80px;
  height: 80px;
  max-width: 80px;
  max-height: 80px;
  border-radius: 6px;
  padding: 0;
  margin-bottom: 5px;
}

.parts-collection-list .heavy-duty-collection-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Titles smaller and wrapped */
.parts-collection-list .heavy-duty-collection-item span {
  font-size: 12px;
  text-align: center;
  display: block;
  white-space: normal;
  word-break: break-word;
  line-height: 1.2;
}

{% comment %} trialer sub category carousel {% endcomment %}
.xtrailer-category-carousel {
  width: 100%;
  overflow: hidden;
  padding: 18px 0 14px;
  position: relative;
}

.xtrailer-category-track {
