    <div class="payments-banner-content">
      <p>Four payments of <strong><span class="mtf-monthly">{{ current_variant.price | divided_by: 4 | money }}</span></strong> per fortnight*</p>
    </div>
  </div>

  <!-- Zip -->
  <!-- Zip -->
<div class="zip-payments-banner payments-banner">
