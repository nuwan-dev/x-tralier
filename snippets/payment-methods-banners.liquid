  border-color: #AA8FFF;   
}

.mtf-payments-banner {
  background-color: #fffbe6; 
  border-color: #F5C716; 
  
} */

</style>

<div class="payments-stack-container">
  {% comment %} <!-- Gem by Latitude -->
  <div class="gem-payments-banner payments-banner">
    <img src="https://cdn.shopify.com/s/files/1/0280/1598/4674/files/Gem-By-Latitude-Logo-Blue-RGB.webp?v=1727806200" alt="Gem by Latitude">
    <div class="payments-banner-content">
      <p>6 months interest-free from <strong><span class="mtf-monthly">{{ current_variant.price | divided_by: 6 | money }}</span></strong> per month*</p>
      <p>12 months interest-free from <strong><span class="mtf-monthly">{{ current_variant.price | divided_by: 12 | money }}</span></strong> per month*</p>
    </div>
  </div> {% endcomment %}

  <!-- Afterpay -->
  <div class="afterpay-payments-banner payments-banner">
