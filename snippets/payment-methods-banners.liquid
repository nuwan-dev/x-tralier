{%- assign current_variant = product.selected_or_first_available_variant -%}

<style>
  .payments-stack-container {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: -20px 0px 16px 0px;
  }

  .payments-banner {
    display: flex;
    align-items: center;
    background-color: #f9f9f9;
    border: 1px solid #dcdcdc;
    border-radius: 0;
    padding: 10px 16px;
    margin: 0;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .payments-banner img {
    flex-shrink: 0;
    width: 45px;
    height: 28px;
    object-fit: contain;
    margin-right: 16px;
  }

  .payments-banner-content {
    flex: 1;
  }

  .payments-banner-content p {
    color: #333;
    font-size: 12px;
    line-height: 18px;
    margin: 0 0 0px;
  }

  .payments-banner-content strong {
    color: #111;
    font-weight: 600;
  }

  /* 🎨 Branded Hover Styles */
  .gem-payments-banner:hover {
    background-color: #e6f0ff;
    border-color: #0074c8;
  }

  .afterpay-payments-banner:hover {
    background-color: #eafaf5;
    border-color: #00bfa5;
  }

 .zip-payments-banner:hover {
  background-color: #f9f5ff;
  border-color: #AA8FFF;   
}

.mtf-payments-banner:hover {
  background-color: #fffbe6; 
  border-color: #F5C716;    

