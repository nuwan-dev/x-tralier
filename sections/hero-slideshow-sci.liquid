{% comment %}
  SECTION: Hero + Slideshow (Right)
  File: sections/hero-slideshow-sci.liquid
{% endcomment %}

<section
  id="HeroSlideshow-{{ section.id }}"
  class="heroSlideshow"
  style="
    --bg: {{ section.settings.bg_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --container: {{ section.settings.container_max }}px;
    --gap: {{ section.settings.col_gap }}px;

    --leftW: {{ section.settings.left_width }}%;
    --rightW: {{ 100 | minus: section.settings.left_width }}%;

    --cardRadius: {{ section.settings.media_radius }}px;
    --cardShadow: {{ section.settings.media_shadow }};
    --mediaH: {{ section.settings.media_height }}px;

    --hSize: {{ section.settings.heading_size }}px;
    --tSize: {{ section.settings.text_size }}px;

    --btnRadius: {{ section.settings.button_radius }}px;
    --btnPadY: {{ section.settings.button_pad_y }}px;
    --btnPadX: {{ section.settings.button_pad_x }}px;

    --primaryBg: {{ section.settings.primary_btn_bg }};
    --primaryText: {{ section.settings.primary_btn_text }};
    --secondaryBorder: {{ section.settings.secondary_btn_border }};
    --secondaryText: {{ section.settings.secondary_btn_text }};

    --accent: {{ section.settings.accent }};
  "
  data-autoplay="{{ section.settings.autoplay }}"
  data-interval="{{ section.settings.autoplay_speed }}"
  data-transition="{{ section.settings.transition }}"
  data-pause-hover="{{ section.settings.pause_on_hover }}"
>
  <div class="heroSlideshow__container">
    <div class="heroSlideshow__grid">

      <!-- LEFT: Content -->
      <div class="heroSlideshow__left">
        {% if section.settings.badge_text != blank %}
          <div class="heroSlideshow__badge">
            {% if section.settings.badge_icon %}
              <span class="heroSlideshow__badgeIcon" aria-hidden="true">
                <!-- SVG Badge Icon -->
                <img
  src="https://cdn.shopify.com/s/files/1/0541/9538/8609/files/Frame.svg?v=1770355692" 
  width="19" 
  height="19" 
                >
              </span>
            {% endif %}
            <span class="heroSlideshow__badgeText">{{ section.settings.badge_text }}</span>
          </div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h1 class="heroSlideshow__heading">{{ section.settings.heading }}</h1>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="heroSlideshow__text rte">
            {{ section.settings.text }}
          </div>
        {% endif %}

        <div class="heroSlideshow__buttons">
          {% if section.settings.primary_btn_label != blank %}
            <a class="heroBtn heroBtn--primary" href="{{ section.settings.primary_btn_link | default: '#' }}">
              {{ section.settings.primary_btn_label }}
            </a>
          {% endif %}

          {% if section.settings.secondary_btn_label != blank %}
            <a class="heroBtn heroBtn--secondary" href="{{ section.settings.secondary_btn_link | default: '#' }}">
              {{ section.settings.secondary_btn_label }}
            </a>
          {% endif %}
        </div>
      </div>

      <!-- RIGHT: Slideshow -->
      <div class="heroSlideshow__right">
        <div class="heroSlideshow__mediaCard">

          <div class="heroSlideshow__slider" role="region" aria-label="Hero slideshow">
            <div class="heroSlideshow__track">
              {% assign slide_index = 0 %}
              {% for block in section.blocks %}
                {% if block.type == 'slide' %}
                  {% assign slide_index = slide_index | plus: 1 %}
                  <div class="heroSlideshow__slide" data-slide="{{ slide_index }}" {{ block.shopify_attributes }}>
                    <div class="heroSlideshow__slideInner">

                      {% if block.settings.image != blank %}
                        {{
                          block.settings.image
                          | image_url: width: 2400
                          | image_tag:
                            loading: 'lazy',
                            class: 'heroSlideshow__img',
                            alt: block.settings.image_alt
                        }}
                      {% else %}
                        <div class="heroSlideshow__placeholder">
                          Add a slide image (recommended 1600px+ wide).
                        </div>
                      {% endif %}

                      {% assign show_caption = false %}
                      {% if block.settings.caption_enable %}
                        {% if block.settings.caption_title != blank %}
                          {% assign show_caption = true %}
                        {% endif %}
                        {% if block.settings.caption_text != blank %}
                          {% assign show_caption = true %}
                        {% endif %}
                      {% endif %}

                      {% if show_caption %}
                        <div class="heroSlideshow__caption">
                          {% if block.settings.caption_title != blank %}
                            <div class="heroSlideshow__capTitle">{{ block.settings.caption_title }}</div>
                          {% endif %}
                          {% if block.settings.caption_text != blank %}
                            <div class="heroSlideshow__capText">{{ block.settings.caption_text }}</div>
                          {% endif %}
                        </div>
                      {% endif %}

                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>

            {% if section.settings.show_arrows %}
              <button class="heroSlideshow__arrow heroSlideshow__arrow--prev" type="button" aria-label="Previous slide">
                <span aria-hidden="true">‹</span>
              </button>
              <button class="heroSlideshow__arrow heroSlideshow__arrow--next" type="button" aria-label="Next slide">
                <span aria-hidden="true">›</span>
              </button>
            {% endif %}

            {% if section.settings.show_dots %}
              <div class="heroSlideshow__dots" aria-label="Slideshow pagination"></div>
            {% endif %}
          </div>

          {% comment %} Feature strip (below image) {% endcomment %}
          {% assign feature_count = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'feature' %}
              {% assign feature_count = feature_count | plus: 1 %}
            {% endif %}
          {% endfor %}

          {% if feature_count > 0 %}
            <div class="heroSlideshow__features">
              {% assign f_i = 0 %}
              {% for block in section.blocks %}
                {% if block.type == 'feature' %}
                  {% assign f_i = f_i | plus: 1 %}
                  <div class="heroFeature" style="--delay: {{ f_i | times: 60 }}ms" {{ block.shopify_attributes }}>
                    {% if block.settings.title != blank %}
                      <div class="heroFeature__title">{{ block.settings.title }}</div>
                    {% endif %}
                    {% if block.settings.text != blank %}
                      <div class="heroFeature__text">{{ block.settings.text }}</div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}

        </div>
      </div>

    </div>
  </div>

  <style>
    #HeroSlideshow-{{ section.id }}.heroSlideshow{
      background: var(--bg);
      padding-top: var(--pt);
      padding-bottom: var(--pb);
      overflow: hidden;
    }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__container{
      max-width: var(--container);
      margin: 0 auto;
      padding: 0 20px;
    }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__grid{
      display: grid;
      grid-template-columns: minmax(0, var(--leftW)) minmax(0, var(--rightW));
      gap: var(--gap);
      align-items: center;
    }
    @media (max-width: 990px){
      #HeroSlideshow-{{ section.id }} .heroSlideshow__grid{ grid-template-columns: 1fr; }
      #HeroSlideshow-{{ section.id }} .heroSlideshow__right{ order: 2; }
      #HeroSlideshow-{{ section.id }} .heroSlideshow__left{ order: 1; }
    }

    #HeroSlideshow-{{ section.id }} .heroSlideshow__badge{
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border: 1px solid rgba(0,0,0,0.14);
      background: rgba(255,255,255,0.65);
      backdrop-filter: blur(6px);
      border-radius: 999px;
      padding: 8px 12px;
      font-size: 14px;
      line-height: 1;
      color: rgba(0,0,0,0.85);
      transform: translateY(6px);
      opacity: 0;
      animation: hsInUp .65s ease forwards;
    }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__badgeIcon{ color: var(--accent); display: inline-flex; }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__heading{
      font-size: var(--hSize);
      line-height: 1.05;
      margin: 18px 0 14px;
      letter-spacing: -0.02em;
      color: rgba(0,0,0,0.92);
      transform: translateY(10px);
      opacity: 0;
      animation: hsInUp .75s ease .05s forwards;
      white-space: pre-line;
    }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__text{
      font-size: var(--tSize);
      line-height: 1.6;
      color: rgba(0,0,0,0.75);
      max-width: 58ch;
      transform: translateY(10px);
      opacity: 0;
      animation: hsInUp .75s ease .12s forwards;
    }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__buttons{
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 26px;
      transform: translateY(10px);
      opacity: 0;
      animation: hsInUp .75s ease .18s forwards;
    }
    #HeroSlideshow-{{ section.id }} .heroBtn{
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      border-radius: var(--btnRadius);
      padding: var(--btnPadY) var(--btnPadX);
      font-weight: 600;
      font-size: 15px;
      transition: transform .2s ease, box-shadow .2s ease, background .2s ease, color .2s ease, border-color .2s ease;
      will-change: transform;
    }
    #HeroSlideshow-{{ section.id }} .heroBtn:active{ transform: translateY(1px); }
    #HeroSlideshow-{{ section.id }} .heroBtn--primary{
      background: var(--primaryBg);
      color: var(--primaryText);
      border: 1px solid rgba(0,0,0,0.08);
      box-shadow: 0 10px 22px rgba(0,0,0,0.10);
    }
    #HeroSlideshow-{{ section.id }} .heroBtn--primary:hover{
      transform: translateY(-1px);
      box-shadow: 0 14px 28px rgba(0,0,0,0.14);
    }
    #HeroSlideshow-{{ section.id }} .heroBtn--secondary{
      background: rgba(255,255,255,0.65);
      color: var(--secondaryText);
      border: 1px solid var(--secondaryBorder);
      backdrop-filter: blur(6px);
    }
    #HeroSlideshow-{{ section.id }} .heroBtn--secondary:hover{
      transform: translateY(-1px);
      box-shadow: 0 12px 24px rgba(0,0,0,0.08);
    }

    #HeroSlideshow-{{ section.id }} .heroSlideshow__mediaCard{
      border-radius: calc(var(--cardRadius) + 4px);
      background: rgba(255,255,255,0.60);
      border: 1px solid rgba(0,0,0,0.10);
      box-shadow: var(--cardShadow);
      overflow: hidden;
    }

    #HeroSlideshow-{{ section.id }} .heroSlideshow__slider{
      position: relative;
      height: var(--mediaH);
      background: #f2f2f2;
      overflow: hidden;
    }
    @media (max-width: 990px){
      #HeroSlideshow-{{ section.id }} .heroSlideshow__slider{
        height: {{ section.settings.media_height_mobile }}px;
      }
    }

    #HeroSlideshow-{{ section.id }} .heroSlideshow__track{
      height: 100%;
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: 100%;
      will-change: transform;
      transform: translate3d(0,0,0);
    }

    #HeroSlideshow-{{ section.id }} .heroSlideshow__slide{ position: relative; height: 100%; }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__slideInner{ position: relative; height: 100%; }

    #HeroSlideshow-{{ section.id }} .heroSlideshow__img{
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 1s ease-out;
    }

    #HeroSlideshow-{{ section.id }} .is-slide .heroSlideshow__track{
      transition: transform 650ms cubic-bezier(.2,.8,.2,1);
    }

    #HeroSlideshow-{{ section.id }} .heroSlideshow__slide.is-active .heroSlideshow__img{
      animation: hsKenBurns {{ section.settings.kenburns_duration }}s ease-in-out both;
    }
    @keyframes hsKenBurns{
      0%{ transform: scale(1.03) translate3d(0,0,0); }
      100%{ transform: scale(1.10) translate3d(-1.5%, -1.5%, 0); }
    }

    #HeroSlideshow-{{ section.id }} .heroSlideshow__caption{
      position: absolute;
      left: 16px;
      bottom: 16px;
      max-width: 70%;
      padding: 12px 14px;
      border-radius: 14px;
      background: rgba(0,0,0,0.55);
      color: #fff;
      backdrop-filter: blur(6px);
      border: 1px solid rgba(255,255,255,0.16);
      transform: translateY(8px);
      opacity: 0;
      transition: opacity .45s ease, transform .45s ease;
    }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__slide.is-active .heroSlideshow__caption{
      opacity: 1;
      transform: translateY(0);
    }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__capTitle{ font-weight: 700; margin-bottom: 2px; font-size: 14px; }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__capText{ font-size: 13px; opacity: 0.9; line-height: 1.35; }

    #HeroSlideshow-{{ section.id }} .heroSlideshow__arrow{
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 42px;
      height: 42px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.22);
      background: rgba(0,0,0,0.35);
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: transform .2s ease, background .2s ease, opacity .2s ease;
      opacity: 0.0;
      pointer-events: none;
    }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__arrow span{ font-size: 26px; line-height: 1; }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__arrow--prev{ left: 12px; }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__arrow--next{ right: 12px; }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__slider:hover .heroSlideshow__arrow{
      opacity: 1; pointer-events: auto;
    }
    #HeroSlideshow-{{ section.id }} .heroSlideshow__arrow:hover{
      background: rgba(0,0,0,0.5);
      transform: translateY(-50%) scale(1.03);
    }

    #HeroSlideshow-{{ section.id }} .heroSlideshow__dots{
      position: absolute;
      left: 16px;
      top: 16px;
      display: flex;
      gap: 8px;
      z-index: 3;
    }
    #HeroSlideshow-{{ section.id }} .heroDot{
      width: 9px;
      height: 9px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.55);
      background: rgba(255,255,255,0.25);
      cursor: pointer;
      transition: transform .2s ease, background .2s ease, width .2s ease;
    }
    #HeroSlideshow-{{ section.id }} .heroDot.is-active{
      background: rgba(255,255,255,0.92);
      width: 18px;
    }

    #HeroSlideshow-{{ section.id }} .heroSlideshow__placeholder{
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 18px;
      text-align: center;
      color: rgba(0,0,0,0.6);
      background: linear-gradient(135deg, rgba(0,0,0,0.05), rgba(0,0,0,0.02));
    }

    #HeroSlideshow-{{ section.id }} .heroSlideshow__features{
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      background: rgba(255,255,255,0.70);
      border-top: 1px solid rgba(0,0,0,0.10);
    }
    @media (max-width: 700px){
      #HeroSlideshow-{{ section.id }} .heroSlideshow__features{ grid-template-columns: 1fr; }
      #HeroSlideshow-{{ section.id }} .heroFeature{
        border-right: 0 !important;
        border-bottom: 1px solid rgba(0,0,0,0.10);
      }
      #HeroSlideshow-{{ section.id }} .heroFeature:last-child{ border-bottom: 0; }
    }
    #HeroSlideshow-{{ section.id }} .heroFeature{
      padding: 16px 18px;
      border-right: 1px solid rgba(0,0,0,0.10);
      opacity: 0;
      transform: translateY(10px);
      animation: hsInUp .7s ease forwards;
      animation-delay: var(--delay, 0ms);
    }
    #HeroSlideshow-{{ section.id }} .heroFeature:last-child{ border-right: 0; }
    #HeroSlideshow-{{ section.id }} .heroFeature__title{ font-weight: 700; color: rgba(0,0,0,0.9); margin-bottom: 6px; }
    #HeroSlideshow-{{ section.id }} .heroFeature__text{ color: rgba(0,0,0,0.68); line-height: 1.45; font-size: 14px; }

    @keyframes hsInUp{
      from{ opacity: 0; transform: translateY(10px); }
      to{ opacity: 1; transform: translateY(0); }
    }

    @media (prefers-reduced-motion: reduce){
      #HeroSlideshow-{{ section.id }} .heroSlideshow__badge,
      #HeroSlideshow-{{ section.id }} .heroSlideshow__heading,
      #HeroSlideshow-{{ section.id }} .heroSlideshow__text,
      #HeroSlideshow-{{ section.id }} .heroSlideshow__buttons,
      #HeroSlideshow-{{ section.id }} .heroFeature{
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
      }
      #HeroSlideshow-{{ section.id }} .heroSlideshow__slide.is-active .heroSlideshow__img{
        animation: none !important;
      }
      #HeroSlideshow-{{ section.id }} .is-slide .heroSlideshow__track{
        transition: none !important;
      }
    }
  </style>

  <script>
    (function(){
      const root = document.getElementById("HeroSlideshow-{{ section.id }}");
      if(!root) return;

      const track = root.querySelector(".heroSlideshow__track");
      const slides = Array.from(root.querySelectorAll(".heroSlideshow__slide"));
      const dotsWrap = root.querySelector(".heroSlideshow__dots");
      const prevBtn = root.querySelector(".heroSlideshow__arrow--prev");
      const nextBtn = root.querySelector(".heroSlideshow__arrow--next");

      const autoplay = root.dataset.autoplay === "true";
      const interval = Math.max(1500, parseInt(root.dataset.interval || "4500", 10));
      const transition = (root.dataset.transition || "slide").toLowerCase();
      const pauseHover = root.dataset.pauseHover === "true";

      if(slides.length === 0) return;

      root.classList.toggle("is-slide", transition === "slide");

      let index = 0;
      let timer = null;
      let isHovering = false;

      let dots = [];
      if(dotsWrap){
        dotsWrap.innerHTML = "";
        dots = slides.map((_, i) => {
          const b = document.createElement("button");
          b.type = "button";
          b.className = "heroDot";
          b.setAttribute("aria-label", "Go to slide " + (i+1));
          b.addEventListener("click", () => goTo(i, true));
          dotsWrap.appendChild(b);
          return b;
        });
      }

      function setActiveClasses(){
        slides.forEach((s, i) => s.classList.toggle("is-active", i === index));
        if(dots.length){
          dots.forEach((d, i) => d.classList.toggle("is-active", i === index));
        }
      }

      function applyTransform(animate){
        if(!animate){
          track.style.transition = "none";
          requestAnimationFrame(() => {
            track.style.transform = "translate3d(" + (-index * 100) + "%,0,0)";
            requestAnimationFrame(() => { track.style.transition = ""; });
          });
        } else {
          track.style.transform = "translate3d(" + (-index * 100) + "%,0,0)";
        }
      }

      function goTo(i, userAction){
        index = (i + slides.length) % slides.length;
        setActiveClasses();
        applyTransform(true);
        if(userAction) restartAutoplay();
      }

      function next(userAction){ goTo(index + 1, userAction); }
      function prev(userAction){ goTo(index - 1, userAction); }

      function startAutoplay(){
        if(!autoplay || slides.length < 2) return;
        stopAutoplay();
        timer = setInterval(() => {
          if(pauseHover && isHovering) return;
          next(false);
        }, interval);
      }
      function stopAutoplay(){
        if(timer){ clearInterval(timer); timer = null; }
      }
      function restartAutoplay(){ stopAutoplay(); startAutoplay(); }

      if(nextBtn) nextBtn.addEventListener("click", () => next(true));
      if(prevBtn) prevBtn.addEventListener("click", () => prev(true));

      if(pauseHover){
        root.addEventListener("mouseenter", () => { isHovering = true; });
        root.addEventListener("mouseleave", () => { isHovering = false; });
      }

      let startX = null;
      const slider = root.querySelector(".heroSlideshow__slider");
      if(slider && slides.length > 1){
        slider.addEventListener("touchstart", (e) => {
          startX = e.touches && e.touches[0] ? e.touches[0].clientX : null;
        }, {passive:true});
        slider.addEventListener("touchend", (e) => {
          if(startX == null) return;
          const endX = e.changedTouches && e.changedTouches[0] ? e.changedTouches[0].clientX : startX;
          const dx = endX - startX;
          startX = null;
          if(Math.abs(dx) > 40){
            dx < 0 ? next(true) : prev(true);
          }
        }, {passive:true});
      }

      setActiveClasses();
      applyTransform(false);
      startAutoplay();
    })();
  </script>
</section>

{% schema %}
{
  "name": "Hero + Slideshow (Right)",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#FFF9F0" },
    { "type": "range", "id": "container_max", "label": "Container max width (px)", "min": 960, "max": 1600, "step": 20, "default": 1240 },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 0, "max": 140, "step": 4, "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 0, "max": 140, "step": 4, "default": 64 },
    { "type": "range", "id": "col_gap", "label": "Column gap (px)", "min": 12, "max": 80, "step": 2, "default": 40 },
    { "type": "range", "id": "left_width", "label": "Left column width (%)", "min": 35, "max": 60, "step": 1, "default": 46 },

    { "type": "header", "content": "Badge" },
    { "type": "checkbox", "id": "badge_icon", "label": "Show badge icon", "default": true },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Build for New Zealand Conditions" },
    { "type": "color", "id": "accent", "label": "Accent color", "default": "#1C4ED8" },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "label": "Heading size (px)", "min": 28, "max": 72, "step": 1, "default": 52 },
    { "type": "range", "id": "text_size", "label": "Text size (px)", "min": 14, "max": 22, "step": 1, "default": 16 },

    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Heavy-Duty Trailers Built\nfor New Zealand Conditions" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Explore our range of high-quality trailers and get expert advice from a local New Zealand team you can rely on.</p>" },

    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "primary_btn_label", "label": "Primary button label", "default": "View Trailer Range" },
    { "type": "url", "id": "primary_btn_link", "label": "Primary button link" },
    { "type": "color", "id": "primary_btn_bg", "label": "Primary button background", "default": "#F2B233" },
    { "type": "color", "id": "primary_btn_text", "label": "Primary button text", "default": "#0B0B0B" },

    { "type": "text", "id": "secondary_btn_label", "label": "Secondary button label", "default": "Get a Quote" },
