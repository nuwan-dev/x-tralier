    { "type": "checkbox", "id": "payment_display_discover", "label": "Discover" },
    { "type": "image_picker", "id": "icon_discover", "label": "Discover image" },

    { "type": "checkbox", "id": "payment_display_dogecoin", "label": "Dogecoin" },
    { "type": "image_picker", "id": "icon_dogecoin", "label": "Dogecoin image" },

    { "type": "checkbox", "id": "payment_display_dwolla", "label": "Dwolla" },
    { "type": "image_picker", "id": "icon_dwolla", "label": "Dwolla image" },

    { "type": "checkbox", "id": "payment_display_forbrugsforeningen", "label": "Forbrugsforeningen" },
    { "type": "image_picker", "id": "icon_forbrugsforeningen", "label": "Forbrugsforeningen image" },

    { "type": "checkbox", "id": "payment_display_interac", "label": "Interac" },
    { "type": "image_picker", "id": "icon_interac", "label": "Interac image" },

    { "type": "checkbox", "id": "payment_display_jcb", "label": "JCB" },
    { "type": "image_picker", "id": "icon_jcb", "label": "JCB image" },

    { "type": "checkbox", "id": "payment_display_litecoin", "label": "Litecoin" },
    { "type": "image_picker", "id": "icon_litecoin", "label": "Litecoin image" },

    { "type": "checkbox", "id": "payment_display_stripe", "label": "Stripe" },
    { "type": "image_picker", "id": "icon_stripe", "label": "Stripe image" },

    { "type": "checkbox", "id": "payment_display_sage", "label": "Sage" },
    { "type": "image_picker", "id": "icon_sage", "label": "Sage image" },

    { "type": "checkbox", "id": "payment_display_wallet", "label": "Google Wallet" },
