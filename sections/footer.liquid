    { "type": "checkbox", "id": "payment_display_visa_electron", "label": "Visa Electron" },
    { "type": "image_picker", "id": "icon_visa_electron", "label": "Visa Electron image" },

    { "type": "checkbox", "id": "payment_display_american_express", "label": "American Express" },
    { "type": "image_picker", "id": "icon_american_express", "label": "American Express image" },

    { "type": "checkbox", "id": "payment_display_maestro", "label": "Maestro" },
    { "type": "image_picker", "id": "icon_maestro", "label": "Maestro image" },

    { "type": "checkbox", "id": "payment_display_solo", "label": "Solo" },
    { "type": "image_picker", "id": "icon_solo", "label": "Solo image" },

    { "type": "checkbox", "id": "payment_display_bitcoin", "label": "Bitcoin" },
    { "type": "image_picker", "id": "icon_bitcoin", "label": "Bitcoin image" },

    { "type": "checkbox", "id": "payment_display_cirrus", "label": "Cirrus" },
    { "type": "image_picker", "id": "icon_cirrus", "label": "Cirrus image" },

    { "type": "checkbox", "id": "payment_display_dankort", "label": "Dankort" },
    { "type": "image_picker", "id": "icon_dankort", "label": "Dankort image" },

