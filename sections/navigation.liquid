{%- comment -%}
  X-TRAILERS Sticky Navigation Bar
  - Desktop: Boxed layout, CTA button.
  - Mobile: Hamburger Icon, Accordion Menu.
  - FIX: Pre-loaded Critical CSS to prevent "Broken/FOUC" flash on load.
{%- endcomment -%}

{%- assign nav_uid = section.id | replace: '-', '' | downcase -%}
{%- assign menu_handle = section.settings.horizontal_linklist -%}

<style>
  /* Fix Drawer Flash: Hide immediately */
  #xt-mobile-drawer-{{ nav_uid }} {
    position: fixed; top: 0; left: 0;
    width: 300px; max-width: 85vw; height: 100%;
    background: #fff; z-index: 2147483641;
    transform: translateX(-100%);
    visibility: hidden; /* Key fix */
    display: flex; flex-direction: column;
    box-shadow: 2px 0 10px rgba(0,0,0,0.1);
    /* Delay transition so it doesn't animate on page load */
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), visibility 0s linear 0.3s;
  }
  
  /* Show when active */
  #xt-mobile-drawer-{{ nav_uid }}.is-active {
    transform: translateX(0);
    visibility: visible;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), visibility 0s linear 0s;
  }

  /* Fix Overlay Flash */
  #xt-mobile-overlay-{{ nav_uid }} {
    position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
    background: rgba(0,0,0,0.5); z-index: 2147483640;
    opacity: 0; visibility: hidden;
    transition: opacity 0.3s ease, visibility 0s linear 0.3s;
  }
  #xt-mobile-overlay-{{ nav_uid }}.is-active {
    opacity: 1; visibility: visible;
    transition: opacity 0.3s ease, visibility 0s linear 0s;
  }

  /* Fix Desktop Nav Stacking Flash */
  @media (min-width: 1200px) {
    .xt-nav-{{ nav_uid }} .xt-nav-flex {
      display: flex !important;
      align-items: center;
      justify-content: space-between;
    }
    .xt-mobile-toggle-wrap { display: none !important; }
  }
</style>

{% render 'style-navigation' %}

<div class="wrapper-navigation xt-nav-{{ nav_uid }}" data-sticky-pc {{ section.shopify_attributes }}>
  
  {% if section.settings.display_fixtop_menu and section.settings.logo_fix != blank %}
    <div class="header-logo logo-fixed">
      <a class="logo-img" href="{{ routes.cart_url | split: 'cart' | first }}" title="Logo">
        <img
          data-src="{{ section.settings.logo_fix | img_url: 'master' }}"
          src="{{ section.settings.logo_fix | img_url: 'master' }}"
          alt="{{ section.settings.logo_fix.alt | default: shop.name }}"
          itemprop="logo"
          class="lazyautosizes lazyloaded"
          data-sizes="auto">
      </a>
    </div>
  {% endif %}

  <div class="main-menu jas-mb-style">
    <div class="container xt-nav-container">
      <div class="row">
        <div class="col-12">
          <div class="mb-area xt-nav-flex">
            
            <div class="xt-mobile-toggle-wrap">
              <button type="button" class="xt-mobile-hamburger" aria-label="Open Menu">
                <span class="xt-bar"></span>
                <span class="xt-bar"></span>
                <span class="xt-bar"></span>
              </button>
            </div>

            <nav class="nav-bar xt-desktop-nav" role="navigation">
              {% render 'site-nav' %}
            </nav>

            {%- if section.settings.xt_show_cta -%}
              <div class="xt-nav-cta-wrap">
                <a class="xt-nav-cta"
                   href="{{ section.settings.xt_cta_link }}"
                   {% if section.settings.xt_cta_new_tab %}target="_blank" rel="noopener"{% endif %}
                   aria-label="{{ section.settings.xt_cta_text | escape }}">
                  {{ section.settings.xt_cta_text }}
                </a>
              </div>
            {%- endif -%}
            
          </div>
        </div>
      </div>
    </div>
  </div>

  {% if section.settings.display_fixtop_menu %}
    <div class="fixed-right-menu">
      <div class="search-fixed">
        <a href="#" title="Search Icon" class="icon-search" data-search-mobile-toggle>
          {% render 'icon-search' %}
        </a>
      </div>
      <div class="cart-fixed cart-icon"{% if settings.header_layout == '02' or settings.header_layout == '03' %} data-cart-header-02 {% endif %}>
        <a href="javascript:void(0)" title="Cart Icon" {% if settings.header_layout == '02' or settings.header_layout == '03' %} data-cart-toggle {% endif %}>
          {% render 'icon-cart' %}
          <span class="cartCount" data-cart-count>{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  {% endif %}
</div>

<div class="xt-mobile-drawer-overlay" id="xt-mobile-overlay-{{ nav_uid }}"></div>
<div class="xt-mobile-drawer" id="xt-mobile-drawer-{{ nav_uid }}">
  
  <div class="xt-drawer-header">
    <span class="xt-drawer-title">Menu</span>
    <button type="button" class="xt-drawer-close" aria-label="Close Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>

  <div class="xt-drawer-content">
    <ul class="xt-mb-list">
      {% for link in linklists[menu_handle].links %}
        <li class="xt-mb-item {% if link.links != blank %}has-children{% endif %}">
          <div class="xt-mb-link-wrap">
            <a href="{{ link.url }}" class="xt-mb-link">{{ link.title }}</a>
            {% if link.links != blank %}
              <button type="button" class="xt-mb-arrow">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </button>
            {% endif %}
          </div>

          {% if link.links != blank %}
            <ul class="xt-mb-sub">
              {% for childlink in link.links %}
                <li class="xt-mb-item {% if childlink.links != blank %}has-children{% endif %}">
                  <div class="xt-mb-link-wrap">
                    <a href="{{ childlink.url }}" class="xt-mb-link">{{ childlink.title }}</a>
                    {% if childlink.links != blank %}
                      <button type="button" class="xt-mb-arrow">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                      </button>
                    {% endif %}
                  </div>
                  
                  {% if childlink.links != blank %}
                    <ul class="xt-mb-sub">
                      {% for grandchildlink in childlink.links %}
                        <li class="xt-mb-item">
                          <a href="{{ grandchildlink.url }}" class="xt-mb-link">{{ grandchildlink.title }}</a>
                        </li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</div>

<style>
  /* ===== X-Trailers Navigation Base ===== */
  .xt-nav-{{ nav_uid }}{
    background: {{ section.settings.xt_nav_bg }};
    position: relative;
    z-index: 100;
    {% if section.settings.xt_border_enable %}
      border-top: {{ section.settings.xt_border_size }}px solid {{ section.settings.xt_border_color }};
    {% endif %}
  }

  .xt-nav-{{ nav_uid }} .xt-nav-container{
    max-width: {{ section.settings.xt_nav_max_width }}px;
    padding-left: {{ section.settings.xt_nav_side_pad }}px;
    padding-right: {{ section.settings.xt_nav_side_pad }}px;
    margin: 0 auto;
  }

  /* ===== Desktop Layout (>= 1200px) ===== */
  @media (min-width: 1200px){
    /* Critical styles handled at top, these are refinements */
    .xt-nav-{{ nav_uid }} .xt-nav-flex{
      gap: 16px;
      min-height: {{ section.settings.xt_nav_height }}px;
    }

    .xt-nav-{{ nav_uid }} .xt-nav-flex .nav-bar{
      display: block;
      flex: 1 1 auto;
      min-width: 0;
    }

    .xt-nav-{{ nav_uid }} .xt-nav-cta-wrap{
      flex: 0 0 auto;
      display:flex;
      align-items:center;
      justify-content:flex-end;
    }

    .xt-nav-{{ nav_uid }} .xt-nav-cta{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      background: {{ section.settings.xt_cta_bg }};
      color: {{ section.settings.xt_cta_text_color }};
      border: {{ section.settings.xt_cta_border_size }}px solid {{ section.settings.xt_cta_border_color }};
      border-radius: {{ section.settings.xt_cta_radius }}px;
      padding: {{ section.settings.xt_cta_pad_y }}px {{ section.settings.xt_cta_pad_x }}px;
      font-size: {{ section.settings.xt_cta_font_size }}px;
      font-weight: {{ section.settings.xt_cta_font_weight }};
      line-height: 1;
      white-space: nowrap;
      transition: all .2s ease;
      text-decoration: none;
    }
    .xt-nav-{{ nav_uid }} .xt-nav-cta:hover{
      background: {{ section.settings.xt_cta_bg_hover }};
      color: {{ section.settings.xt_cta_text_hover }};
      border-color: {{ section.settings.xt_cta_border_hover }};
      transform: translateY(-1px);
    }
  }

  /* ===== Mobile Layout (< 1199px) ===== */
  @media (max-width: 1199px){
    /* Hide old menu strictly */
    .xt-nav-{{ nav_uid }} .xt-desktop-nav {
      display: none !important; 
    }

    /* Flex Row: Hamburger Left, CTA Right */
    .xt-nav-{{ nav_uid }} .xt-nav-flex{
      display: flex !important;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 10px 0;
      width: 100%;
    }

    /* Hamburger Icon */
    .xt-mobile-toggle-wrap {
      display: block !important;
      flex: 0 0 auto;
    }
    
    .xt-mobile-hamburger {
      background: none;
      border: none;
      cursor: pointer;
      padding: 10px;
      width: 44px;
      height: 44px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      gap: 6px;
    }
    
    /* Force Hamburger Color to match CTA Text Color so it is visible */
    .xt-mobile-hamburger .xt-bar {
      display: block;
      width: 24px;
      height: 2px;
      background-color: {{ section.settings.xt_cta_text_color | default: '#000000' }}; 
      border-radius: 2px;
    }

    /* CTA Logic Mobile */
    {% if section.settings.xt_hide_cta_mobile %}
      .xt-nav-{{ nav_uid }} .xt-nav-cta-wrap{ display:none !important; }
    {% else %}
      .xt-nav-{{ nav_uid }} .xt-nav-cta-wrap{
        flex: 0 0 auto;
        display:flex;
        justify-content:flex-end;
      }
      .xt-nav-{{ nav_uid }} .xt-nav-cta{
        display:inline-flex;
        align-items:center;
        justify-content:center;
        background: {{ section.settings.xt_cta_bg }};
        color: {{ section.settings.xt_cta_text_color }};
        border: {{ section.settings.xt_cta_border_size }}px solid {{ section.settings.xt_cta_border_color }};
        border-radius: {{ section.settings.xt_cta_radius }}px;
        padding: 10px 18px;
        font-size: 14px;
        font-weight: 600;
        line-height: 1;
        white-space: nowrap;
        text-decoration: none;
      }
    {% endif %}
  }

  /* Drawer Aesthetics */
  .xt-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 20px;
    border-bottom: 1px solid #eee;
    background: #f9f9f9;
  }
  .xt-drawer-title {
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    color: #000;
  }
  .xt-drawer-close {
    background: none;
    border: none;
    cursor: pointer;
    color: #333;
    padding: 5px;
  }

  .xt-drawer-content {
    flex: 1;
    overflow-y: auto;
    padding: 0;
    background: #fff;
  }
  
  .xt-mb-list { list-style: none; margin: 0; padding: 0; }
  .xt-mb-item { border-bottom: 1px solid #f5f5f5; }
  .xt-mb-link-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #fff;
  }
  .xt-mb-link {
    display: block;
    padding: 15px 20px;
    color: #333;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    flex: 1;
  }
  .xt-mb-arrow {
    background: none;
    border: none;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-left: 1px solid #f5f5f5;
    transition: background 0.2s ease;
  }
  .xt-mb-arrow.is-open {
    background: #f0f0f0;
  }
  
  .xt-mb-sub {
    display: none; /* Hidden by default */
    list-style: none;
    margin: 0;
    padding: 0;
    background: #f9f9f9;
  }
  .xt-mb-sub .xt-mb-link {
    padding-left: 35px;
    font-weight: 400;
    color: #555;
    font-size: 14px;
    border-bottom: 1px solid #eee;
  }
  .xt-mb-sub .xt-mb-sub .xt-mb-link {
    padding-left: 50px;
    color: #777;
  }

  /* Existing fix for sticky width */
  @media (min-width:1200px) {
    {% unless section.settings.logo_fix != blank %}
    .header-lang-style2 .is-sticky .main-menu,
    .wrapper_header_default .is-sticky .main-menu {
      width: calc(100% - 112px);
      margin-left: 112px;
    }
    {% endunless %}
    .site-nav .mega-menu .style_5 .mega-banner { background-color: {{ section.settings.bg_style_new }}; }
  }
</style>

<script>
  window.fixtop_menu = {{ section.settings.display_fixtop_menu | json }};

  (function() {
    function initMobileMenu() {
      // Unique ID scoping
      var navUid = "{{ nav_uid }}";
      var drawer = document.getElementById("xt-mobile-drawer-" + navUid);
      var overlay = document.getElementById("xt-mobile-overlay-" + navUid);
      var trigger = document.querySelector(".xt-nav-" + navUid + " .xt-mobile-hamburger");
      var closeBtn = drawer ? drawer.querySelector(".xt-drawer-close") : null;

      if(trigger && drawer && overlay) {
        // Remove old listeners (if any) to prevent duplicates (basic safety)
        var newTrigger = trigger.cloneNode(true);
        trigger.parentNode.replaceChild(newTrigger, trigger);
        trigger = newTrigger;

        // Open
        trigger.addEventListener("click", function(e) {
          e.preventDefault();
          drawer.classList.add("is-active");
          overlay.classList.add("is-active");
          document.body.style.overflow = "hidden";
        });

        // Close Functions
        function closeDrawer() {
          drawer.classList.remove("is-active");
          overlay.classList.remove("is-active");
          document.body.style.overflow = "";
        }

        if(closeBtn) closeBtn.addEventListener("click", closeDrawer);
        overlay.addEventListener("click", closeDrawer);
      }

      // Accordion Logic
      var arrows = document.querySelectorAll("#xt-mobile-drawer-" + navUid + " .xt-mb-arrow");
      arrows.forEach(function(arrow) {
        // Clone to clear old events
        var newArrow = arrow.cloneNode(true);
        arrow.parentNode.replaceChild(newArrow, arrow);
        
        newArrow.addEventListener("click", function(e) {
          e.preventDefault();
          e.stopPropagation(); // Stop bubbling
          var subMenu = this.parentNode.nextElementSibling;
          if(subMenu && subMenu.classList.contains("xt-mb-sub")) {
            if (subMenu.style.display === "block") {
              subMenu.style.display = "none";
              this.classList.remove("is-open");
            } else {
              subMenu.style.display = "block";
              this.classList.add("is-open");
            }
          }
        });
      });
    }

    // Run immediately AND on load to ensure it catches
    initMobileMenu();
    document.addEventListener("DOMContentLoaded", initMobileMenu);
    // If using Shopify Theme Editor
    document.addEventListener("shopify:section:load", initMobileMenu);
  })();
</script>

{% schema %}
{
  "name": "Navigation",
  "max_blocks": 15,
  "settings": [
    {
      "type": "header",
      "content": "X-Trailers Bar Layout"
    },
    {
      "type": "range",
      "id": "xt_nav_max_width",
      "label": "Boxed max width (px)",
      "min": 900,
      "max": 1920,
      "step": 20,
      "default": 1440
    },
    {
      "type": "range",
      "id": "xt_nav_side_pad",
      "label": "Side padding (px)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "xt_nav_height",
      "label": "Desktop height (px)",
      "min": 48,
      "max": 110,
      "step": 2,
      "default": 76
    },
    {
      "type": "color",
      "id": "xt_nav_bg",
      "label": "Bar background",
      "default": "#000000"
    },

    {
      "type": "header",
      "content": "Top Border"
    },
    {
      "type": "checkbox",
      "id": "xt_border_enable",
      "label": "Enable top border",
      "default": true
    },
    {
      "type": "range",
      "id": "xt_border_size",
      "label": "Border size (px)",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "xt_border_color",
      "label": "Border color",
      "default": "#111111"
    },

    {
      "type": "header",
      "content": "Right CTA Button"
    },
    {
      "type": "checkbox",
      "id": "xt_show_cta",
      "label": "Show CTA button",
      "default": true
    },
    {
      "type": "text",
      "id": "xt_cta_text",
      "label": "Button text",
      "default": "Get a Quote"
    },
    {
      "type": "url",
      "id": "xt_cta_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "xt_cta_new_tab",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "type": "color",
      "id": "xt_cta_bg",
      "label": "Button background",
      "default": "#f4a321"
    },
    {
      "type": "color",
      "id": "xt_cta_text_color",
      "label": "Button text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "xt_cta_border_color",
      "label": "Button border color",
      "default": "#f4a321"
    },
    {
      "type": "range",
      "id": "xt_cta_border_size",
      "label": "Button border size (px)",
      "min": 0,
      "max": 6,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "xt_cta_radius",
      "label": "Button radius (px)",
      "min": 0,
      "max": 18,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "xt_cta_pad_x",
      "label": "Button padding X (px)",
      "min": 10,
      "max": 50,
      "step": 2,
      "default": 26
    },
    {
      "type": "range",
      "id": "xt_cta_pad_y",
      "label": "Button padding Y (px)",
      "min": 8,
      "max": 26,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "xt_cta_font_size",
      "label": "Button font size (px)",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 18
    },
    {
      "type": "select",
      "id": "xt_cta_font_weight",
      "label": "Button font weight",
      "default": "500",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "SemiBold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "color",
      "id": "xt_cta_bg_hover",
      "label": "Button hover background",
      "default": "#ffb84a"
    },
    {
      "type": "color",
      "id": "xt_cta_text_hover",
      "label": "Button hover text",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "xt_cta_border_hover",
      "label": "Button hover border",
      "default": "#ffb84a"
    },
    {
      "type": "checkbox",
      "id": "xt_hide_cta_mobile",
      "label": "Hide CTA on mobile",
      "default": false
    },

    {
      "type": "header",
      "content": "Fixed Top Menu"
    },
    {
      "type": "checkbox",
      "id": "display_fixtop_menu",
      "label": "Display Fix Top Menu?",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "logo_fix",
      "label": "Logo image when enable Fixed Top Menu",
      "info": "95px x 44px recommended"
    },
    {
      "type": "link_list",
      "id": "horizontal_linklist",
      "label": "Menu",
      "default": "main-menu"
    },

    {
      "type": "header",
      "content": "Navigation Text alignment"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },

    {
      "type" : "header",
      "content" : "Settings"
    },
    {
      "type" : "color",
      "id" : "bg_menu",
      "label" : "Background Main Menu",
      "default" : "#232323"
    },
    {
      "type" : "color",
      "id" : "bg_dropdown_menu",
      "label" : "Background Dropdown Menu",
      "default" : "#fff",
      "info" : "======================="
    },
    {
      "type" : "color",
      "id" : "color_menu_lv1",
      "label" : "Level 1 Menu Color",
      "default" : "#fff"
    },
    {
      "type" : "color",
      "id" : "hover_color_mnu_lv1",
      "label" : "Level 1 Menu color when hover",
      "default" : "#fff"
    },
    {
      "type" : "text",
      "id" : "font_size_mnu_lv1",
      "label" : "Font size Menu level 1",
      "default" : "13px",
      "info" : "======================="
    },
    {
      "type" : "color",
      "id" : "color_menu_lv2",
      "label" : "Level 2 Menu Color",
      "default" : "#232323"
    },
    {
      "type" : "color",
      "id" : "hover_color_mnu_lv2",
      "label" : "Level 2 Menu color when hover",
      "default" : "#232323"
    },
    {
      "type" : "text",
      "id" : "font_size_mnu_lv2",
      "label" : "Font size Menu level 2",
      "default" : "12px",
      "info" : "======================="
    },
    {
      "type" : "color",
      "id" : "color_menu_lv3",
      "label" : "Level 3 Menu Color",
      "default" : "#3c3c3c"
    },
    {
