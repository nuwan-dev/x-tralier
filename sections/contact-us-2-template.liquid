<div class="contact-us-page">

  <div class="container">
    {% render 'breadcrumb' %}
    
    <header class="page-heading">
      <h2>
        {{ section.settings.contact_title | split: '|' | first }}
      </h2>
      {% render 'multilang-block' with section.settings.contact_text_desc, class:'des' %}
    </header> 
    
    {% if page.content != blank %}
    <div class="rte">
      {{ page.content }}
    </div>
    {% endif %}
    
    <div class="wrapper">
      <div class="row contact-form-row">
        <div class="col-md-7 col-lg-8 col-xl-7 form-contact"> 
          {% if request.params.product %}
            <div class="enquiry-product-title">
              <strong>Enquiry for:</strong> {{ request.params.product }}
            </div>
          {% endif %}   
          <div id="enquiryProductTitle" class="enquiry-product-title" style="display:none;"></div> 
          <div class="form-heading">
            <h3 class="title">
              {% render 'multilang' with section.settings.form_title %}
            </h3>
            <p>
              {% render 'multilang' with section.settings.form_subtitle %}
            </p>  
          </div>
          
          {% form 'contact' %}

            {% if request.params.product %}
              <input type="hidden" name="contact[Product Name]" value="{{ request.params.product }}">
            {% endif %}

          {% if form.posted_successfully? %}
          <p class="note form-success" {% if settings.enable_multilang %}data-translate="contact.form.post_success"{% endif %}>
            {{ 'contact.form.post_success' | t }}
          </p>
          {% endif %}
          <input type="hidden" name="contact[Product Name]" id="enquiryProductInput" value="">

          {{ form.errors | default_errors }}

          <div id="contactFormWrapper">          
            <div class="form-group">
              <label for="contactFormName">
                <span {% if settings.enable_multilang %}data-translate="contact.form.name"{% endif %}>
                  {{ 'contact.form.name' | t }}
                </span>
                <em>*</em>
              </label>
              <input
                type="text"
                id="contactFormName"
                name="contact[name]"
                autocapitalize="words"
                placeholder="{{ section.settings.contact_your_name }}"
                required
              >
            </div>

            <div class="form-group">
              <label for="contactFormPhone">
                <span {% if settings.enable_multilang %}data-translate="contact.form.phone"{% endif %}>
                  {{ 'contact.form.phone' | t }}
                </span>
                <em>*</em>
              </label>
              <input
                type="tel"
                name="contact[phone]"
                id="contactFormPhone"
                pattern="[0-9]*"
                placeholder="{{ section.settings.contact_phone_number }}"
                required
              >
            </div>

            <div class="form-group">
              <label for="contactFormEmail">
                <span {% if settings.enable_multilang %}data-translate="contact.form.email"{% endif %}>
                  {{ 'contact.form.email' | t }}
                </span>
                <em>*</em>
              </label>
              <input
                type="email"
                name="contact[email]"
                id="contactFormEmail"
                autocorrect="off"
                autocapitalize="off"
                placeholder="{{ section.settings.contact_your_email }}"
                required
              >
            </div>

            <div class="form-group">
              <label for="contactFormCity">
                <span {% if settings.enable_multilang %}data-translate="Your City"{% endif %}>
                  Your Location
                </span>
                <em>*</em>
              </label>
              <input
                type="text"
                name="contact[City]"
                id="contactFormCity"
                required
              >
            </div>

            <div class="form-group">
              <label for="contactFormMessage">
                <span>Additional notes</span>
              </label>
              <textarea
                rows="8"
                name="contact[body]"
                id="contactFormMessage"
                {% if settings.enable_multilang %}data-translate="contact.form.placeholder_message" translate-item="placeholder"{% endif %}
              ></textarea>
            </div>

            <input type="submit" class="btn" value="Submit">
          </div>
          {% endform %}
        </div>
        
        {% if section.settings.display_location %}
        <div class="col-md-5 info">
          <div class="inner">
            {% if section.settings.top_title != '' and section.settings.top_content != '' %}
              <div class="info-block top-content">
                {% if section.settings.top_title != '' %}
                  <h3 class="title">
                    {% render 'multilang' with section.settings.top_title %}
                  </h3>
                  {% if section.settings.top_content != '' %}
                    {% render 'multilang-block' with section.settings.top_content, class: 'info-content' %}
                  {% endif %}
                {% endif %}
                <a href="mailto:{{section.settings.email}}" class="btn">
                  {% render 'multilang' with section.settings.email_button %}
                </a>
              </div>
            {% endif %}
            {% if section.settings.bot_content != '' and section.settings.bot_title != '' %}
              <div class="info-block">
                {% if section.settings.bot_title != '' %}
                  <h3 class="title">
                    {% render 'multilang' with section.settings.bot_title %}
                  </h3>
                {% endif %}
                {% if section.settings.bot_content != '' %}
                  {% render 'multilang-block' with section.settings.bot_content, class: 'info-content' %}
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
        {% endif %}
      </div>     
    </div>
  </div>    
</div>
<script>
document.addEventListener('DOMContentLoaded', function () {
  const params = new URLSearchParams(window.location.search);
  const product = params.get('product');

  if (product) {
    const cleanProduct = product.replace(/\+/g, ' ');
    
    const titleBox = document.getElementById('enquiryProductTitle');
    const hiddenInput = document.getElementById('enquiryProductInput');

    if (titleBox) {
      titleBox.innerHTML = '<strong>Enquiry for:</strong> ' + cleanProduct;
      titleBox.style.display = 'block';
    }

    if (hiddenInput) {
      hiddenInput.value = cleanProduct;
    }
  }
});
</script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  const form = document.querySelector('#contact_form');
  if (!form) return;

  form.addEventListener('submit', function () {
    const googleScriptUrl = 'https://script.google.com/macros/s/AKfycbwgYaa1nL5qJ1ZNoIt2o0oaUlTNhQH2o-ebtXBce-tNd6AENMDPOw7_KHB3Kmgq_JCo/exec';

    const data = new FormData();

    data.append('date', new Date().toLocaleString());
    data.append('product_name', document.getElementById('enquiryProductInput')?.value || '');
    data.append('name', document.getElementById('contactFormName')?.value || '');
    data.append('email', document.getElementById('contactFormEmail')?.value || '');
    data.append('phone', document.getElementById('contactFormPhone')?.value || '');
    data.append('location', document.getElementById('contactFormCity')?.value || '');
    data.append('message', document.getElementById('contactFormMessage')?.value || '');
    data.append('page_url', window.location.href);

    navigator.sendBeacon(googleScriptUrl, data);
  });
});
</script>
<style>
  .page-heading:before {
  display: none !important;
}
  .enquiry-product-title {
  text-align: center;
  font-size: 32px;
  font-weight: 700;
  margin-bottom: 20px;
  color: #222;
  line-height: 1.4;
}
  .page-heading {
    text-align: center;
    position: relative;
    width: 70%;
    margin: 0 auto 55px;
  }

  .page-heading:before {
    content: '';
    display: block;
    width: 30%;
    max-width: 315px;
    height: 1px;
    background-color: #a6a6a6;
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
  }

  .page-heading h2 {
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.05em;
    font-size: 30px;
    margin-bottom: 22px;
  }

  .page-heading .des {
    padding-bottom: 18px;
    margin-bottom: 0;
  }

  .contact-form-row {
    justify-content: center;
  }

  .form-contact {
    padding-top: 40px;
    margin: 0 auto;
    float: none;
  }

  .form-heading {
    margin-bottom: 25px;
    text-align: center;
  }

  .form-heading h3.title {
    font-size: {{ settings.body_font_size | plus: 2 }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 26px;
  }

  #contactFormWrapper {
    max-width: 700px;
    margin: 0 auto;
  }

  .contact-form input[type="text"],
  .contact-form input[type="tel"],
  .contact-form input[type="email"],
  .contact-us-page .form-group textarea,
  #contactFormWrapper input[type="text"],
  #contactFormWrapper input[type="tel"],
  #contactFormWrapper input[type="email"],
  #contactFormWrapper textarea {
    max-width: 100%;
    width: 100%;
  }

  #contactFormWrapper .btn {
    min-width: 180px;
    text-transform: uppercase;
  }

  .info .inner {
    background-color: {{ section.settings.background_color }};
    padding: 40px 55px;
  }

  .info .top-content {
    margin-bottom: 50px;
  }

  .info h3.title {
    text-transform: uppercase;
    font-weight: 700;
    font-size: {{ settings.body_font_size | plus: 2 }}px;
    letter-spacing: 0.05em;
    margin-bottom: 25px;
  }

  .info .info-content {
    line-height: {{ settings.body_font_size | plus: 12 }}px;
  }

  .info .top-content .info-content {
    margin-bottom: 25px;
  }

  .info .top-content .btn {
    background-color: #F4A321 !important;
    color: {{ section.settings.email_button_txtc }};
    border-color: {{ section.settings.email_button_bdc }};
    margin-top: 0;
  }
  .contact-us-page .btn{
    background-color: #F4A321 !important;
  }

  .info .top-content .btn:hover {
    background-color: {{ section.settings.email_button_bgc_h }};
    color: {{ section.settings.email_button_txtc_h }};
    border-color: {{ section.settings.email_button_bdc_h }};
  }
  
  @media (max-width: 991px) {
    .info .inner {
      padding: 40px 20px;
    }

    .page-heading h2 {
      font-size: 24px;
    }
  }

  @media (max-width: 767px) {
    .page-heading h2 {
      font-size: 20px;
    }

    .page-heading {
      width: 100%;
    }

    .form-contact {
      padding-top: 20px;
    }
  }
</style>