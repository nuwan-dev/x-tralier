{% comment %}
  SECTION: Advanced Features Section with Adjustable Padding
  File: sections/features-horizontal-adjustable-padding.liquid
{% endcomment %}

<section 
  id="FeaturesSection-{{ section.id }}" 
  class="features-section" 
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background-color: {{ section.settings.bg_color }};">
  
  <div class="features-container" style="max-width: {{ section.settings.container_max }}px;">
    <div class="features-wrapper">
      {% assign feature_count = 0 %}
      
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          {% assign feature_count = feature_count | plus: 1 %}
          
          <div class="feature-card" style="border: {{ section.settings.card_border_width }} solid {{ section.settings.card_border_color }}; border-radius: {{ section.settings.card_border_radius }}px; padding: {{ section.settings.card_padding_top }}px {{ section.settings.card_padding_right }}px {{ section.settings.card_padding_bottom }}px {{ section.settings.card_padding_left }}px;">
            <div class="feature-card-content">
              <div class="feature-card-image">
                {% if block.settings.icon != blank %}
                  <img src="{{ block.settings.icon | img_url: '1600x1600' }}" alt="{{ block.settings.title }}" class="feature-card-img" style="width: {{ section.settings.image_size }}px; height: auto; object-fit: cover;">
                {% endif %}
              </div>
              <div class="feature-card-text" style="flex-basis: {{ section.settings.right_width }}%;">
                <h3 style="font-size: {{ section.settings.title_size }}px;">{{ block.settings.title }}</h3>
                <p style="font-size: {{ section.settings.desc_size }}px;">{{ block.settings.text }}</p>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
  
</section>

<style>
  .features-section {
    padding-top: 30px;
    padding-bottom: 30px;
    background-color: #FFFAF3;
    border-top:solid 1px #D3D3D3;
    border-bottom:solid 1px #D3D3D3;
  }

  .features-container {
    margin: 0 auto;
    padding: 0 20px;
  }

  .features-wrapper {
    display: grid;
    grid-template-columns: repeat({{ section.settings.cards_per_row }}, 1fr); /* Adjust cards per row */
    gap: {{ section.settings.col_gap }}px;
  }

  .feature-card {
    background: #fff;
    border-radius: 8px;
    border:solid 1px #D3D3D3;
    display: flex;
    flex-direction: row;
    align-items: center;
    {% comment %} box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1); {% endcomment %}
  }

  .feature-card-content {
    display: flex;
    align-items: center;
    width: 100%;
  }

  .feature-card-image {
    width: auto;
    margin-right: 20px; /* Space between image and title */
  }

  .feature-card-img {
    width: 100%; /* Ensure image takes the set size */
    height: auto;
    object-fit: cover;
  }

  .feature-card-text {
    flex-grow: 1;
  }

  .feature-card-text h3 {
    font-size: 18px;
    margin-bottom: 10px;
  }

  .feature-card-text p {
    color: #555;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .features-wrapper {
      grid-template-columns: 1fr 1fr; /* 2 cards per row on mobile */
    }

    .feature-card-content {
      flex-direction: column; /* Stack the image and text vertically on mobile */
      align-items: flex-start;
    }

    .feature-card-image {
      width: 100%;
      margin-bottom: 15px; /* Add spacing between image and title */
    }
  }
</style>

