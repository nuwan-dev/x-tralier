      "id": "heading_size",
      "label": "Card heading size (px)",
      "min": 18,
      "max": 56,
      "step": 2,
      "default": 34
    },
    {
      "type": "range",
      "id": "heading_weight",
      "label": "Card heading weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Card heading color",
      "default": "#111111"
    },

    { "type": "header", "content": "Body text style" },
    {
      "type": "range",
      "id": "text_size",
      "label": "Body text size (px)",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text color",
      "default": "#2b2b2b"
    },

    { "type": "header", "content": "Button style" },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button font size (px)",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "button_weight",
      "label": "Button font weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 500
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#f5a623"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button radius (px)",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "button_py",
      "label": "Button padding Y (px)",
      "min": 8,
      "max": 22,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "button_px",
      "label": "Button padding X (px)",
      "min": 14,
      "max": 40,
      "step": 1,
      "default": 22
    }
  ],
  "presets": [
    {
      "name": "Split image + content card"
    }
  ]
}
{% endschema %}
