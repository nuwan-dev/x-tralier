{%- comment -%}
  FIX: Shopify schema "range" default must have 1 or less decimal digits
  Changed title_letter_spacing default from 0.01 -> 0.0
{%- endcomment -%}

{%- assign uid = section.id | replace: '-', '' | downcase -%}

{% style %}
  .xf-{{ uid }}{
    padding: {{ section.settings.section_padding_y }}px {{ section.settings.section_padding_x }}px;
    background: {{ section.settings.section_bg }};
  }

  .xf-wrap-{{ uid }}{
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .xf-card-{{ uid }}{
    background: {{ section.settings.card_bg }};
    border-radius: {{ section.settings.card_radius }}px;
    border: 1px solid {{ section.settings.card_border }};
    padding: {{ section.settings.card_padding }}px;
  }

  .xf-grid-{{ uid }}{
    display: grid;
    grid-template-columns: 0.9fr 1.6fr;
    gap: {{ section.settings.grid_gap }}px;
    align-items: start;
  }

  .xf-left-{{ uid }}{
    padding: {{ section.settings.left_padding }}px;
  }

  .xf-badge-{{ uid }}{
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: {{ section.settings.badge_radius }}px;
    border: 1px solid {{ section.settings.badge_border }};
    background: {{ section.settings.badge_bg }};
    color: {{ section.settings.badge_text_color }};
    font-size: {{ section.settings.badge_font_size }}px;
    font-weight: 500;
    line-height: 1;
    margin-bottom: {{ section.settings.badge_gap }}px;
    user-select: none;
  }
  .xf-badge-{{ uid }} svg{
    width: 18px;
    height: 18px;
    display: block;
    fill: currentColor;
  }

  .xf-title-{{ uid }}{
    margin: 0 0 {{ section.settings.title_gap }}px;
    font-size: {{ section.settings.title_size }}px;
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.title_color }};
    letter-spacing: {{ section.settings.title_letter_spacing }}em;
    line-height: 1.05;
    text-transform: {{ section.settings.title_transform }};
  }

  .xf-desc-{{ uid }}{
    margin: 0 0 {{ section.settings.desc_gap }}px;
    font-size: {{ section.settings.desc_size }}px;
    color: {{ section.settings.desc_color }};
    line-height: 1.6;
    max-width: 36ch;
  }

  .xf-btn-{{ uid }}{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.button_py }}px {{ section.settings.button_px }}px;
    border-radius: {{ section.settings.button_radius }}px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_color }};
    text-decoration: none;
    font-size: {{ section.settings.button_size }}px;
    font-weight: {{ section.settings.button_weight }};
    border: 1px solid rgba(0,0,0,0);
    transition: transform .15s ease, filter .15s ease, box-shadow .15s ease;
  }
  .xf-btn-{{ uid }}:hover{
    filter: brightness(0.96);
    box-shadow: 0 10px 24px rgba(0,0,0,0.10);
  }
  .xf-btn-{{ uid }}:active{ transform: translateY(1px); }

  .xf-right-{{ uid }}{
    padding: {{ section.settings.right_padding }}px;
  }

  .xf-accordion-{{ uid }}{
    border-radius: {{ section.settings.accordion_radius }}px;
    overflow: hidden;
  }

  .xf-item-{{ uid }}{
    border-top: 1px solid {{ section.settings.divider_color }};
  }
  .xf-item-{{ uid }}:first-child{ border-top: 0; }

  .xf-q-{{ uid }}{
    width: 100%;
    background: transparent;
    border: 0;
    padding: {{ section.settings.q_py }}px {{ section.settings.q_px }}px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    cursor: pointer;
    text-align: left;
  }

  .xf-qtext-{{ uid }}{
    font-size: {{ section.settings.q_size }}px;
    font-weight: {{ section.settings.q_weight }};
    color: {{ section.settings.q_color }};
    line-height: 1.3;
  }

  .xf-chevron-{{ uid }}{
    width: {{ section.settings.chevron_size }}px;
    height: {{ section.settings.chevron_size }}px;
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    transition: transform .2s ease;
    color: {{ section.settings.chevron_color }};
  }
  .xf-chevron-{{ uid }} svg{
    width: 100%;
    height: 100%;
    display: block;
    fill: currentColor;
  }

  .xf-a-{{ uid }}{
    display: none;
    padding: 0 {{ section.settings.q_px }}px {{ section.settings.a_pb }}px {{ section.settings.q_px }}px;
    color: {{ section.settings.a_color }};
    font-size: {{ section.settings.a_size }}px;
    line-height: 1.65;
  }
  .xf-a-{{ uid }} p{ margin: 0 0 10px; }
  .xf-a-{{ uid }} p:last-child{ margin-bottom: 0; }

  .xf-item-{{ uid }}[data-open="true"] .xf-a-{{ uid }}{ display: block; }
  .xf-item-{{ uid }}[data-open="true"] .xf-chevron-{{ uid }}{ transform: rotate(180deg); }

  .xf-q-{{ uid }}:hover .xf-qtext-{{ uid }}{ opacity: 0.92; }

  @media (max-width: 989px){
    .xf-grid-{{ uid }}{
      grid-template-columns: 1fr;
      gap: calc({{ section.settings.grid_gap }}px * 0.8);
    }
    .xf-left-{{ uid }}, .xf-right-{{ uid }}{ padding: 0; }
    .xf-desc-{{ uid }}{ max-width: none; }
  }

  @media (max-width: 749px){
    .xf-{{ uid }}{
      padding: calc({{ section.settings.section_padding_y }}px * 0.75) calc({{ section.settings.section_padding_x }}px * 0.75);
    }
    .xf-card-{{ uid }}{
      padding: calc({{ section.settings.card_padding }}px * 0.75);
    }
    .xf-title-{{ uid }}{
      font-size: calc({{ section.settings.title_size }}px * 0.82);
    }
    .xf-qtext-{{ uid }}{
      font-size: calc({{ section.settings.q_size }}px * 0.95);
    }
    .xf-btn-{{ uid }}{ width: 100%; }
  }
{% endstyle %}

<section class="xf-{{ uid }}" {{ section.shopify_attributes }}>
  <div class="xf-wrap-{{ uid }}">
    <div class="xf-card-{{ uid }}">
      <div class="xf-grid-{{ uid }}">
        <div class="xf-left-{{ uid }}">
          {%- if section.settings.show_badge -%}
            <div class="xf-badge-{{ uid }}">
              {%- if section.settings.badge_icon == 'shield' -%}
                <img
  src="https://cdn.shopify.com/s/files/1/0541/9538/8609/files/Frame.svg?v=1770355692" 
  width="19" 
  height="19" 
                >
              {%- else -%}
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path d="M9 21h6v-1H9v1zm3-20C8.1 1 5 4.1 5 8c0 2.4 1.2 4.5 3 5.7V17c0 .6.4 1 1 1h6c.6 0 1-.4 1-1v-3.3c1.8-1.2 3-3.3 3-5.7 0-3.9-3.1-7-7-7zm2.6 11.1-.6.4V16h-4v-3.5l-.6-.4C8.1 11.3 7 9.7 7 8c0-2.8 2.2-5 5-5s5 2.2 5 5c0 1.7-1.1 3.3-2.4 4.1z"/>
                </svg>
              {%- endif -%}
              <span>{{ section.settings.badge_text }}</span>
            </div>
          {%- endif -%}

          {%- if section.settings.title != blank -%}
            <h2 class="xf-title-{{ uid }}">{{ section.settings.title }}</h2>
          {%- endif -%}

          {%- if section.settings.description != blank -%}
            <div class="xf-desc-{{ uid }}">{{ section.settings.description }}</div>
          {%- endif -%}

          {%- if section.settings.button_label != blank -%}
            <a class="xf-btn-{{ uid }}" href="{{ section.settings.button_link | default: '#' }}">
              {{ section.settings.button_label }}
            </a>
          {%- endif -%}
        </div>

        <div class="xf-right-{{ uid }}">
          <div class="xf-accordion-{{ uid }}" data-xf-accordion>
            {%- for block in section.blocks -%}
              <div class="xf-item-{{ uid }}" {{ block.shopify_attributes }} data-xf-item data-open="{% if forloop.first and section.settings.first_open %}true{% else %}false{% endif %}">
                <button class="xf-q-{{ uid }}" type="button" data-xf-toggle aria-expanded="{% if forloop.first and section.settings.first_open %}true{% else %}false{% endif %}">
                  <span class="xf-qtext-{{ uid }}">{{ block.settings.question }}</span>
                  <span class="xf-chevron-{{ uid }}" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                      <path d="M7.41 8.59 12 13.17l4.59-4.58L18 10l-6 6-6-6z"/>
                    </svg>
                  </span>
                </button>
                <div class="xf-a-{{ uid }}" data-xf-answer>
                  {{ block.settings.answer }}
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const root = document.querySelector('.xf-{{ uid }}');
  if (!root) return;

  const accordion = root.querySelector('[data-xf-accordion]');
  if (!accordion) return;

  const allowMultiple = {{ section.settings.allow_multiple_open | json }};

  accordion.querySelectorAll('[data-xf-item]').forEach(item => {
    const btn = item.querySelector('[data-xf-toggle]');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const isOpen = item.getAttribute('data-open') === 'true';

      if (!allowMultiple) {
        accordion.querySelectorAll('[data-xf-item][data-open="true"]').forEach(openItem => {
          if (openItem === item) return;
          openItem.setAttribute('data-open', 'false');
          const openBtn = openItem.querySelector('[data-xf-toggle]');
          if (openBtn) openBtn.setAttribute('aria-expanded', 'false');
        });
      }

      item.setAttribute('data-open', String(!isOpen));
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });
});
</script>

{% schema %}
{
  "name": "FAQ split",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Container" },
    { "type": "range", "id": "max_width", "label": "Max width (px)", "min": 900, "max": 1800, "step": 50, "default": 1600 },
    { "type": "color", "id": "section_bg", "label": "Section background", "default": "#ffffff" },

    { "type": "header", "content": "Card" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "card_border", "label": "Card border color", "default": "#e9e9e9" },
    { "type": "range", "id": "card_radius", "label": "Card radius (px)", "min": 0, "max": 30, "step": 2, "default": 14 },
    { "type": "range", "id": "card_padding", "label": "Card padding (px)", "min": 12, "max": 60, "step": 2, "default": 26 },

    { "type": "header", "content": "Layout & spacing" },
    { "type": "range", "id": "section_padding_y", "label": "Section padding Y (px)", "min": 0, "max": 120, "step": 4, "default": 40 },
    { "type": "range", "id": "section_padding_x", "label": "Section padding X (px)", "min": 0, "max": 60, "step": 2, "default": 20 },
    { "type": "range", "id": "grid_gap", "label": "Column gap (px)", "min": 16, "max": 80, "step": 2, "default": 40 },
    { "type": "range", "id": "left_padding", "label": "Left column inner padding (px)", "min": 0, "max": 40, "step": 2, "default": 14 },
    { "type": "range", "id": "right_padding", "label": "Right column inner padding (px)", "min": 0, "max": 40, "step": 2, "default": 0 },

    { "type": "header", "content": "Badge" },
    { "type": "checkbox", "id": "show_badge", "label": "Show badge", "default": true },
    {
      "type": "select",
      "id": "badge_icon",
      "label": "Badge icon",
      "options": [
        { "value": "shield", "label": "Shield" },
        { "value": "bulb", "label": "Bulb" }
      ],
      "default": "shield"
    },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Quick answers" },
    { "type": "color", "id": "badge_bg", "label": "Badge background", "default": "#ffffff" },
    { "type": "color", "id": "badge_border", "label": "Badge border", "default": "#e6e6e6" },
    { "type": "color", "id": "badge_text_color", "label": "Badge text color", "default": "#111111" },
    { "type": "range", "id": "badge_font_size", "label": "Badge font size (px)", "min": 10, "max": 18, "step": 1, "default": 13 },
    { "type": "range", "id": "badge_radius", "label": "Badge radius (px)", "min": 0, "max": 18, "step": 1, "default": 6 },
    { "type": "range", "id": "badge_gap", "label": "Gap under badge (px)", "min": 8, "max": 40, "step": 2, "default": 26 },

    { "type": "header", "content": "Left text" },
    { "type": "text", "id": "title", "label": "Left title", "default": "X-TRAILERS FAQ" },
    {
      "type": "select",
      "id": "title_transform",
      "label": "Title transform",
      "options": [
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "none", "label": "None" }
      ],
      "default": "uppercase"
    },
    { "type": "range", "id": "title_size", "label": "Title size (px)", "min": 24, "max": 70, "step": 2, "default": 44 },
    { "type": "range", "id": "title_weight", "label": "Title weight", "min": 300, "max": 900, "step": 100, "default": 800 },
    { "type": "range", "id": "title_letter_spacing", "label": "Title letter spacing (em)", "min": 0, "max": 0.2, "step": 0.1, "default": 0.0 },
    { "type": "color", "id": "title_color", "label": "Title color", "default": "#111111" },

    {
      "type": "richtext",
      "id": "description",
      "label": "Left description",
      "default": "<p>If you can’t find what you’re looking for, get in touch. We’re happy to help!</p>"
    },
    { "type": "range", "id": "desc_size", "label": "Description size (px)", "min": 12, "max": 22, "step": 1, "default": 16 },
    { "type": "color", "id": "desc_color", "label": "Description color", "default": "#222222" },
    { "type": "range", "id": "title_gap", "label": "Gap under title (px)", "min": 6, "max": 40, "step": 2, "default": 22 },
    { "type": "range", "id": "desc_gap", "label": "Gap under description (px)", "min": 10, "max": 60, "step": 2, "default": 26 },

    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Contact Us" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#f4a321" },
    { "type": "color", "id": "button_color", "label": "Button text color", "default": "#111111" },
    { "type": "range", "id": "button_size", "label": "Button font size (px)", "min": 12, "max": 22, "step": 1, "default": 16 },
    { "type": "range", "id": "button_weight", "label": "Button font weight", "min": 300, "max": 900, "step": 100, "default": 500 },
    { "type": "range", "id": "button_radius", "label": "Button radius (px)", "min": 0, "max": 18, "step": 1, "default": 6 },
    { "type": "range", "id": "button_py", "label": "Button padding Y (px)", "min": 8, "max": 22, "step": 1, "default": 12 },
    { "type": "range", "id": "button_px", "label": "Button padding X (px)", "min": 14, "max": 44, "step": 1, "default": 22 },

    { "type": "header", "content": "Accordion" },
    { "type": "checkbox", "id": "first_open", "label": "Open first item by default", "default": false },
    { "type": "checkbox", "id": "allow_multiple_open", "label": "Allow multiple open", "default": false },
    { "type": "range", "id": "accordion_radius", "label": "Accordion radius (px)", "min": 0, "max": 20, "step": 2, "default": 0 },

    { "type": "header", "content": "Accordion question style" },
    { "type": "range", "id": "q_size", "label": "Question font size (px)", "min": 14, "max": 26, "step": 1, "default": 18 },
    { "type": "range", "id": "q_weight", "label": "Question font weight", "min": 300, "max": 900, "step": 100, "default": 500 },
    { "type": "color", "id": "q_color", "label": "Question color", "default": "#111111" },
    { "type": "range", "id": "q_py", "label": "Question padding Y (px)", "min": 14, "max": 34, "step": 1, "default": 24 },
    { "type": "range", "id": "q_px", "label": "Question padding X (px)", "min": 14, "max": 34, "step": 1, "default":20 },

    { "type": "header", "content": "Accordion answer style" },
    { "type": "range", "id": "a_size", "label": "Answer font size (px)", "min": 12, "max": 20, "step": 1, "default": 15 },
    { "type": "color", "id": "a_color", "label": "Answer color", "default": "#2b2b2b" },
    { "type": "range", "id": "a_pb", "label": "Answer bottom padding (px)", "min": 12, "max": 40, "step": 1, "default": 18 },

    { "type": "header", "content": "Dividers & chevron" },
    { "type": "color", "id": "divider_color", "label": "Divider color", "default": "#e6e6e6" },
    { "type": "color", "id": "chevron_color", "label": "Chevron color", "default": "#111111" },
    { "type": "range", "id": "chevron_size", "label": "Chevron size (px)", "min": 16, "max": 28, "step": 1, "default": 20 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How do I choose the right trailer for my needs?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Add your answer here.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ split (X-Trailers style)",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}
